{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:sidecars && npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Nyx",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "minimize": true,
        "maximize": true,
        "unmaximize": true,
        "startDragging": true,
        "setSize": true,
        "setPosition": true
      }
    },
    "bundle": {
     "active": true,
      "targets": ["nsis"],
      "identifier": "com.thazts.ide",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.png",
        "icons/icon.ico"
      ],
    "publisher": "Thazts",
    "externalBin": [
      "extra-bin/nyx-keyman",
       "extra-bin/NyxCli",
       "extra-bin/Charon"
     ],
    "resources": [
      "skills/FengshuiProtocol.md",
      "skills/SelfHelp.md",
      "skills/LuaLuau.md",
      "skills/ViewportManual.md",
      "skills/SecurityReview.md"
    ]
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:; font-src 'self' data:; connect-src 'self' http://localhost:1420 ws://localhost:1420"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "decorations": false,
        "title": "Nyx",
        "width": 960,
        "height": 592
      }
    ]
  }
}
